{
    "rust-analyzer.cargo.features": "all",
    "rust-analyzer.rustfmt.overrideCommand": [
        "leptosfmt",
        "--stdin",
        "--rustfmt"
    ],
    "todo-tree.filtering.excludeGlobs": [
        "**/node_modules/*/**",
        "**/.github/*/**"
    ],
    "cSpell.language": "en-AU",
    "cSpell.diagnosticLevel": "Hint",
    "cSpell.words": [
        "bigdecimal",
        "chrono",
        "CJDNS",
        "clippy",
        "codegen",
        "color",
        "dtolnay",
        "journalctl",
        "journcalctl",
        "mdbook",
        "regtest",
        "rustdoc",
        "rustls",
        "serde",
        "sqlx",
        "thiserror",
        "Uptime"
    ]
}